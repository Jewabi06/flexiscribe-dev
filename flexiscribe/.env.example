# ═══════════════════════════════════════════════════════════════════════════════
# fLexiScribe – Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# On Vercel, set these in Project Settings → Environment Variables.
# This is the ONLY env file the app reads (.env). Do NOT create .env.local etc.

# ── Ollama (AI quiz generation) ──────────────────────────────────────────────
OLLAMA_BASE_URL="http://your-ollama-host:11434"
OLLAMA_MODEL=""
OLLAMA_CONCURRENCY="1"
OLLAMA_TIME_LIMIT_MS="600000"

# ── Python/FastAPI Backend (live transcription) ─────────────────────────────
FASTAPI_URL="http://localhost:8000"
NEXT_PUBLIC_TRANSCRIPTION_API="http://localhost:8000"

# ── Database (PostgreSQL – e.g. Neon, Supabase, Vercel Postgres) ─────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET="generate-a-strong-random-secret-here"
ADMIN_ACCESS_KEY="change-this-in-production"

# ── Frontend URL ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxx"
EMAIL_FROM="fLexiScribe <onboarding@resend.dev>"
